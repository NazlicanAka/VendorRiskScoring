{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/vendor-risk-scoring-.json",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "RiskWeights": {
    "Weights": {
      "Financial": 0.4,
      "Operational": 0.3,
      "SecurityCompliance": 0.3
    }
  },
  "RiskThresholds": {
    "Critical": 0.90,
    "High": 0.70,
    "Medium": 0.40
  },
  "AllowedHosts": "*",
  "FilePaths": {
    "VendorData": "Data/SeedData/SampleVendorData.json",
    "MatrixData": "Data/SeedData/RiskFactorMatrix.json"
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=vendor-db;Port=5432;Database=VendorRiskDB;Username=postgres;Password=supersecretpassword",
    "RedisConnection": "vendor_risk_redis:6379"
  }

  
}